@dashboard_bp.route("/dashboard")
@login_required
def home():
    all_slots = Slot.query.all()
    stats = _build_slot_stats(all_slots)
    return render_template("dashboard.html", stats=stats, slots=all_slots)

from flask import Blueprint, current_app, jsonify, request

from app.extensions import db
from app.services.sensor_service import SimulatedSensorService

api_bp = Blueprint("api", __name__, url_prefix="/api")


def _parse_bool(value):
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in {"1", "true", "yes", "occupied", "on"}:
            return True
        if normalized in {"0", "false", "no", "free", "off"}:
            return False
    return None


@api_bp.route("/sensor/update", methods=["POST"])
def sensor_update():
    expected_api_key = current_app.config.get("PI_API_KEY", "").strip()
    provided_api_key = request.headers.get("X-API-KEY", "").strip()

    if expected_api_key and provided_api_key != expected_api_key:
        return jsonify({"ok": False, "message": "Unauthorized API key."}), 401

    payload = request.get_json(silent=True) or {}
    slot_code = str(payload.get("slot_code", "")).strip().upper()
    is_occupied = _parse_bool(payload.get("is_occupied"))

    if not slot_code:
        return jsonify({"ok": False, "message": "slot_code is required."}), 400
    if is_occupied is None:
        return jsonify({"ok": False, "message": "is_occupied must be boolean-like."}), 400

    sensor_service = SimulatedSensorService()
    slot = sensor_service.update_slot_from_sensor(slot_code, is_occupied)
    if not slot:
        return jsonify({"ok": False, "message": f"Slot '{slot_code}' not found."}), 404

    db.session.commit()
    return jsonify(
        {
            "ok": True,
            "message": "Slot updated successfully.",
            "slot": {
                "slot_code": slot.slot_code,
                "is_occupied": slot.is_occupied,
                "slot_type": slot.slot_type,
            },
        }
    )

Invoke-RestMethod -Uri "http://127.0.0.1:5000/api/sensor/update" `
  -Method Post `
  -Headers @{ "X-API-KEY" = "smart-parking-pi-key" } `
  -ContentType "application/json" `
  -Body '{"slot_code":"B1","is_occupied":true}'

import RPi.GPIO as GPIO
import time
from RPLCD.i2c import CharLCD

# ---------------- SETUP ----------------
GPIO.setmode(GPIO.BCM)

IR = 17
TOUCH = 27
LED_GREEN = 22
LED_RED = 23
BUZZER = 24

GPIO.setup(IR, GPIO.IN)
GPIO.setup(TOUCH, GPIO.IN)
GPIO.setup(LED_GREEN, GPIO.OUT)
GPIO.setup(LED_RED, GPIO.OUT)
GPIO.setup(BUZZER, GPIO.OUT)

lcd = CharLCD('PCF8574', 0x27)

# ---------------- FUNCTIONS ----------------
def lcd_msg(msg):
    lcd.clear()
    lcd.write_string(msg)

def green():
    GPIO.output(LED_GREEN, True)
    GPIO.output(LED_RED, False)

def red():
    GPIO.output(LED_GREEN, False)
    GPIO.output(LED_RED, True)

def buzzer_on():
    GPIO.output(BUZZER, True)

def buzzer_off():
    GPIO.output(BUZZER, False)

# ---------------- MAIN ----------------
try:
    while True:

        # Idle state
        if not GPIO.input(IR):
            lcd_msg("Slot Available")
            green()
            buzzer_off()

        # Vehicle detected
        else:
            lcd_msg("Vehicle Detected")
            green()
            start = time.time()

            while GPIO.input(IR):
                duration = time.time() - start

                # Assist mode
                if GPIO.input(TOUCH):
                    lcd_msg("Assist Mode")
                    buzzer_on()
                    time.sleep(1)
                    buzzer_off()

                # Wrong parking
                elif duration > 5:
                    lcd_msg("Adjust Vehicle")
                    red()
                    buzzer_on()

            buzzer_off()
            lcd_msg("Slot Occupied")
            red()
            time.sleep(2)

        time.sleep(0.3)

except KeyboardInterrupt:
    print("Stopped")

finally:
    GPIO.cleanup()

